{
  "name": "missao-oab",
  "version": "1.0.0",
  "private": true,
  "engines": { "node": ">=20.0.0" },

  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
