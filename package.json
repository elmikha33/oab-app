    "@tailwindcss/typography": "^0.5.20",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "20.11.19",
    "@types/react": "18.2.33",
    "@types/react-dom": "18.2.15",
    "autoprefixer": "10.4.19",
    "eslint": "10.5.0",
    "eslint-config-next": "16.2.9",
    "postcss": "8.4.38",
    "prettier": "3.2.5",
    "tsx": "^4.7.0",
    "typescript": "5.4.2"
