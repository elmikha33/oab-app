    "validate:questoes": "tsx scripts/validateQuestoes.ts",
    "validate:questoes:dry": "tsx scripts/validateQuestoes.ts --dry-run",
    "validate:questoes:all": "tsx scripts/validateQuestoes.ts --all",
    "backfill:numero-questoes": "tsx scripts/backfillNumeroQuestoes.ts",
    "backfill:numero-questoes:dry": "tsx scripts/backfillNumeroQuestoes.ts --dry-run",
    "auditar:comentarios": "tsx scripts/validateQuestoes.ts --auditar-comentarios",
    "sugerir:regras-conhecidas": "tsx scripts/sugerirRegrasConhecidas.ts",
    "reset:revisao": "tsx scripts/resetRevisaoQuestoes.ts"
  },

  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.4.2",
    "groq-sdk": "^1.2.1",
    "lucide-react": "0.400.0",
    "next": "^14.2.5",
    "next-themes": "^0.4.6",
    "openai": "^4.104.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.0",
    "zustand": "^5.0.14"
